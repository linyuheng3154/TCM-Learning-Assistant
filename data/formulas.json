  "formulas": [
    {
      "id": "f001",
      "name": "麻黄汤",
      "pinyin": "mahuang tang",
      "composition": [
        {"herb": "麻黄", "dosage": "9g"},
        {"herb": "桂枝", "dosage": "6g"},
        {"herb": "杏仁", "dosage": "9g"},
        {"herb": "甘草", "dosage": "3g"}
      ],
      "efficacy": "发汗解表，宣肺平喘",
      "indications": "外感风寒表实证，症见恶寒发热，头身疼痛，无汗而喘，舌苔薄白，脉浮紧",
      "contraindications": "表虚自汗、阴虚血少者忌用",
      "usage": "水煎服，温覆取微汗",
      "source": "《伤寒论》",
      "category": "解表剂-辛温解表"
    },
    {
      "id": "f002",
      "name": "桂枝汤",
      "pinyin": "guizhi tang",
      "composition": [
        {"herb": "桂枝", "dosage": "9g"},
        {"herb": "芍药", "dosage": "9g"},
        {"herb": "甘草", "dosage": "6g"},
        {"herb": "生姜", "dosage": "9g"},
        {"herb": "大枣", "dosage": "12枚"}
      ],
      "efficacy": "解肌发表，调和营卫",
      "indications": "外感风寒表虚证，症见头痛发热，汗出恶风，鼻鸣干呕，苔白不渴，脉浮缓或浮弱",
      "contraindications": "表实无汗者忌用",
      "usage": "水煎服，温覆取微汗",
      "source": "《伤寒论》",
      "category": "解表剂-辛温解表"
    },
    {
