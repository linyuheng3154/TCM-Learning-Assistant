        {"herb": "黄芩", "dosage": "9g"},
        {"herb": "人参", "dosage": "6g"},
        {"herb": "半夏", "dosage": "9g"},
        {"herb": "甘草", "dosage": "5g"},
        {"herb": "生姜", "dosage": "9g"},
        {"herb": "大枣", "dosage": "4枚"}
      ],
      "efficacy": "和解少阳",
      "indications": "伤寒少阳证，症见往来寒热，胸胁苦满，默默不欲饮食，心烦喜呕，口苦，咽干，目眩，舌苔薄白，脉弦；妇人伤寒，热入血室，以及疟疾、黄疸等病而见少阳证者",
      "usage": "水煎服",
      "source": "《伤寒论》",
      "category": "和解剂-和解少阳"
    },
