      "name": "银翘散",
      "pinyin": "yinqiao san",
      "composition": [
        {"herb": "金银花", "dosage": "15g"},
        {"herb": "连翘", "dosage": "15g"},
        {"herb": "桔梗", "dosage": "9g"},
        {"herb": "薄荷", "dosage": "6g"},
        {"herb": "竹叶", "dosage": "4g"},
        {"herb": "甘草", "dosage": "5g"},
        {"herb": "荆芥穗", "dosage": "4g"},
        {"herb": "淡豆豉", "dosage": "5g"},
        {"herb": "牛蒡子", "dosage": "9g"}
      ],
      "efficacy": "辛凉透表，清热解毒",
      "indications": "温病初起，发热无汗，或有汗不畅，微恶风寒，头痛口渴，咳嗽咽痛，舌尖红，苔薄白或微黄，脉浮数",
      "usage": "水煎服，或作散剂冲服",
      "source": "《温病条辨》",
      "category": "解表剂-辛凉解表"
    },
    {
      "id": "f004",
      "name": "四君子汤",
      "pinyin": "sijunzi tang",
      "composition": [
        {"herb": "人参", "dosage": "9g"},
        {"herb": "白术", "dosage": "9g"},
        {"herb": "茯苓", "dosage": "9g"},
        {"herb": "甘草", "dosage": "6g"}
      ],
      "efficacy": "益气健脾",
      "indications": "脾胃气虚证，症见面色萎白，语声低微，气短乏力，食少便溏，舌淡苔白，脉虚弱",
      "usage": "水煎服",
      "source": "《太平惠民和剂局方》",
      "category": "补益剂-补气"
    },
    {
      "id": "f005",
      "name": "六味地黄丸",
      "pinyin": "liuweidihuang wan",
      "composition": [
        {"herb": "熟地黄", "dosage": "24g"},
        {"herb": "山茱萸", "dosage": "12g"},
        {"herb": "山药", "dosage": "12g"},
        {"herb": "泽泻", "dosage": "9g"},
        {"herb": "牡丹皮", "dosage": "9g"},
        {"herb": "茯苓", "dosage": "9g"}
      ],
      "efficacy": "滋阴补肾",
      "indications": "肾阴虚证，症见腰膝酸软，头晕目眩，耳鸣耳聋，盗汗，遗精，消渴，骨蒸潮热，手足心热，舌燥咽痛，牙齿动摇，足跟作痛，小便淋沥，以及小儿囟门不合，舌红少苔，脉沉细数",
      "usage": "水煎服，或作丸剂服用",
      "source": "《小儿药证直诀》",
      "category": "补益剂-补阴"
    },
    {
