  "shiba_fan": {
    "name": "十八反",
    "description": "两种药物配伍使用会产生剧烈的毒性反应或副作用，属于配伍禁忌",
    "source": "《本草经集注》",
    "rules": [
      {
        "group": "甘草反",
        "herbs": ["甘草"],
        "incompatible_with": ["大戟", "芫花", "甘遂", "海藻"],
        "note": "甘草与大戟、芫花、甘遂、海藻同用，会产生剧烈不良反应"
      },
      {
        "group": "乌头反",
        "herbs": ["川乌", "草乌", "附子"],
        "incompatible_with": ["半夏", "瓜蒌", "贝母", "白蔹", "白及"],
        "note": "乌头类药物与半夏、瓜蒌、贝母、白蔹、白及同用，增强毒性"
      },
      {
        "group": "藜芦反",
        "herbs": ["藜芦"],
        "incompatible_with": ["人参", "沙参", "丹参", "玄参", "苦参", "细辛", "芍药"],
        "note": "藜芦与人参等补气药同用，会产生剧烈呕吐等毒性反应"
      }
    ],
    "verse": "本草明言十八反，半夏贝母瓜蒌攻，白及白蔹与乌头，海藻大戟甘遂芫花俱战草，诸参辛芍叛藜芦"
  },
  "shijiu_wei": {
